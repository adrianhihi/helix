{
  "name": "@helix-agent/core",
  "version": "0.1.0",
  "description": "Self-healing infrastructure for AI agent payments. PCEC auto-repairs payment failures across Tempo, Privy, Stripe, and any HTTP service.",
  "type": "module",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": "./dist/core/index.js",
    "./tempo": "./dist/platforms/tempo/index.js",
    "./privy": "./dist/platforms/privy/index.js",
    "./generic": "./dist/platforms/generic/index.js"
  },
  "bin": {
    "helix": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "demo": "tsx src/demo/run.ts",
    "demo:tempo": "tsx src/demo/tempo.ts",
    "demo:privy": "tsx src/demo/privy.ts",
    "dash": "tsx src/cli/index.ts dash",
    "helix": "tsx src/cli/index.ts"
  },
  "keywords": ["agent", "payments", "self-healing", "pcec", "mpp", "tempo", "privy", "stripe"],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
